{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-7vd2.vercel.app/api/:path*"
    },
    {
      "source": "/sochiot-auth/:path*",
      "destination": "https://app.sochiot.com/api/auth-engine/:path*"
    },
    {
      "source": "/sochiot-config/:path*",
      "destination": "https://app.sochiot.com/api/config-engine/:path*"
    },
    {
      "source": "/((?!api/|sochiot-auth/|sochiot-config/).*)",
      "destination": "/index.html"
    }
  ]
}
